# ── Python ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
build/
dist/
.pytest_cache/
.coverage
htmlcov/

# ── Environment ─────────────────────────────────────────────────────────
.env
.env.*
!.env.example
.venv/
venv/

# ── ML Artifacts ────────────────────────────────────────────────────────
# Generated training datasets (history lives in /data/ on Railway, not repo).
# Parquets that get regenerated by monthly_retrain or notebook training
# should NEVER be committed; the canonical bootstrap parquets are
# explicitly tracked below as cold-start fallbacks.
*.parquet
# Bootstrap parquets: cold-start fallback quando /data/ do Railway está vazio.
# O monthly_retrain usa BOOTSTRAP_FALLBACK = _REPO_ROOT / "ml_training_merged.parquet".
!ml_training_merged.parquet
!ml_training_fund.parquet
!ml_training_price.parquet

# Generated ML bundles (intermediate, candidate, archive).
# The production bundle dip_models_v3.pkl IS tracked (Railway loads from
# repo, no object storage). Other .pkl files are generated artifacts.
*.pkl
!dip_models_v3.pkl

# Generated training reports (intermediate). The production report
# ml_report_v3.json is tracked (consumed by /admin and health_monitor).
*.json.tmp

# ── Local data (Railway volume mount in production) ────────────────────
data/
/data/

# ── Editor / OS ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.iml

# ── Logs / temp ─────────────────────────────────────────────────────────
*.log
*.tmp
